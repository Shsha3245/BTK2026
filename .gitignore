# ==========================================
# 1. PYTHON & BACKEND KURALLARI (KÖK DİZİN)
# ==========================================
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ==========================================
# 2. FRONTEND KURALLARI (NEXT.JS)
# ==========================================
# Bağımlılıklar
frontend/node_modules/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*

# Derleme Çıktıları ve Testler
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/

# TypeScript & Vercel
